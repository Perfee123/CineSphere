<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="768.0" prefWidth="1024.0" spacing="25.0" style="-fx-background-color: white;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.admin.SalesReportsController" stylesheets="@../ticket/ticket.css">
    <padding>
        <Insets bottom="30.0" left="40.0" right="40.0" top="30.0" />
    </padding>

    <!-- Header Section -->
    <HBox alignment="CENTER_LEFT" spacing="15.0">
        <VBox spacing="5.0">
            <Label text="Sales Reports &amp; Analytics" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #111111;" />
            <Label text="Track earnings, ticket distributions, and visual sales statistics." style="-fx-font-size: 14px; -fx-text-fill: #666666;" />
        </VBox>
        <Region HBox.hgrow="ALWAYS" />
        
        <ComboBox fx:id="timeFilterCombo" promptText="Today" style="-fx-background-color: white; -fx-border-color: #dddddd; -fx-border-radius: 20px; -fx-padding: 2px 10px;" />
        
        <Button text="Generate Report" style="-fx-background-color: #0066ff; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px; -fx-background-radius: 20px; -fx-padding: 8px 20px; -fx-cursor: hand;" onAction="#handleGenerateReport" />
    </HBox>

    <!-- Cards Section -->
    <HBox spacing="15.0">
        <!-- Card 1 -->
        <VBox style="-fx-background-color: #f8f9fa; -fx-background-radius: 8px; -fx-border-color: #e0e0e0; -fx-border-radius: 8px; -fx-border-width: 1px;" HBox.hgrow="ALWAYS">
            <padding>
                <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
            </padding>
            <Label text="Total Revenue" style="-fx-font-size: 13px; -fx-text-fill: #888888;" />
            <Label fx:id="totalRevenueLabel" text="0.00" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #111111;" />
            <Label text="Gross bookings value" style="-fx-font-size: 12px; -fx-text-fill: #999999;" />
        </VBox>

        <!-- Card 2 -->
        <VBox style="-fx-background-color: #f8f9fa; -fx-background-radius: 8px; -fx-border-color: #e0e0e0; -fx-border-radius: 8px; -fx-border-width: 1px;" HBox.hgrow="ALWAYS">
            <padding>
                <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
            </padding>
            <Label text="Tickets Sold" style="-fx-font-size: 13px; -fx-text-fill: #888888;" />
            <Label fx:id="ticketsSoldLabel" text="0" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #111111;" />
            <Label text="Adult &amp; kid admissions" style="-fx-font-size: 12px; -fx-text-fill: #999999;" />
        </VBox>

        <!-- Card 3 -->
        <VBox style="-fx-background-color: #f8f9fa; -fx-background-radius: 8px; -fx-border-color: #e0e0e0; -fx-border-radius: 8px; -fx-border-width: 1px;" HBox.hgrow="ALWAYS">
            <padding>
                <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
            </padding>
            <Label text="Average Ticket Price" style="-fx-font-size: 13px; -fx-text-fill: #888888;" />
            <Label fx:id="avgTicketPriceLabel" text="0.00" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #111111;" />
            <Label text="Calculated average" style="-fx-font-size: 12px; -fx-text-fill: #999999;" />
        </VBox>

        <!-- Card 4 -->
        <VBox style="-fx-background-color: #f8f9fa; -fx-background-radius: 8px; -fx-border-color: #e0e0e0; -fx-border-radius: 8px; -fx-border-width: 1px;" HBox.hgrow="ALWAYS">
            <padding>
                <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
            </padding>
            <Label text="Active Shows" style="-fx-font-size: 13px; -fx-text-fill: #888888;" />
            <Label fx:id="activeShowsLabel" text="0" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #111111;" />
            <Label text="Total shows scheduled" style="-fx-font-size: 12px; -fx-text-fill: #999999;" />
        </VBox>
    </HBox>

    <!-- Chart Section -->
    <HBox spacing="15.0" prefHeight="350.0">
        <VBox style="-fx-border-color: #eeeeee; -fx-border-radius: 8px; -fx-border-width: 1px;" HBox.hgrow="ALWAYS">
            <BarChart fx:id="revenueChart" title="Revenue by Movie" legendVisible="false" style="-fx-font-size: 12px;" VBox.vgrow="ALWAYS" animated="false" categoryGap="20">
                <xAxis>
                    <CategoryAxis label="Movie Title" animated="false" />
                </xAxis>
                <yAxis>
                    <NumberAxis label="Revenue ($)" animated="false" />
                </yAxis>
            </BarChart>
        </VBox>
        <VBox style="-fx-border-color: #eeeeee; -fx-border-radius: 8px; -fx-border-width: 1px;" HBox.hgrow="ALWAYS">
            <PieChart fx:id="audiencePieChart" title="Audience Demographics" legendVisible="true" style="-fx-font-size: 12px;" VBox.vgrow="ALWAYS" />
        </VBox>
    </HBox>

    <!-- Table Section -->
    <VBox spacing="10.0" VBox.vgrow="ALWAYS">
        <Label text="Detailed Transaction Log" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #111111;" />
        
        <TableView fx:id="transactionTable" VBox.vgrow="ALWAYS" style="-fx-background-color: white; -fx-border-color: #e0e0e0; -fx-border-radius: 4px; -fx-border-width: 1px;">
            <columns>
                <TableColumn fx:id="colBookingId" prefWidth="100.0" text="Booking ID" style="-fx-alignment: CENTER;" />
                <TableColumn fx:id="colDateTime" prefWidth="150.0" text="Date/Time" style="-fx-alignment: CENTER;" />
                <TableColumn fx:id="colMovieTitle" prefWidth="200.0" text="Movie Title" style="-fx-alignment: CENTER-LEFT;" />
                <TableColumn fx:id="colAdults" prefWidth="80.0" text="Adults" style="-fx-alignment: CENTER;" />
                <TableColumn fx:id="colKids" prefWidth="80.0" text="Kids" style="-fx-alignment: CENTER;" />
                <TableColumn fx:id="colSoldBy" prefWidth="120.0" text="Sold By" style="-fx-alignment: CENTER;" />
                <TableColumn fx:id="colStatus" prefWidth="100.0" text="Status" style="-fx-alignment: CENTER;" />
                <TableColumn fx:id="colTotalAmount" prefWidth="100.0" text="Total Amount" style="-fx-alignment: CENTER-RIGHT;" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>
    </VBox>
</VBox>
