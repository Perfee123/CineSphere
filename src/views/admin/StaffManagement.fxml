<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.cell.PropertyValueFactory?>

<VBox prefHeight="768.0" prefWidth="774.0" spacing="30.0" style="-fx-background-color: white;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.admin.StaffManagementController" stylesheets="@../ticket/ticket.css">
    <padding>
        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
    </padding>

    <!-- Header Section -->
    <HBox alignment="CENTER_LEFT" spacing="15.0">
        <VBox spacing="5.0">
            <Label text="Staff Management" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #111111;" />
            <Label text="Create and update system user accounts." style="-fx-font-size: 14px; -fx-text-fill: #666666;" />
        </VBox>
        <Region HBox.hgrow="ALWAYS" />
        
        <TextField fx:id="searchField" prefWidth="250.0" promptText="Search staff..." style="-fx-background-radius: 20px; -fx-padding: 8px 15px; -fx-border-color: #dddddd; -fx-border-radius: 20px; -fx-background-color: white;" />
        
        <Button mnemonicParsing="false" onAction="#onAddStaff" text="+ Add Staff" style="-fx-background-color: #0066ff; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px; -fx-background-radius: 20px; -fx-padding: 8px 20px; -fx-cursor: hand;" />
        
        <Button mnemonicParsing="false" onAction="#onEditStaff" text="Edit" style="-fx-background-color: white; -fx-text-fill: #111111; -fx-border-color: #dddddd; -fx-font-weight: bold; -fx-font-size: 14px; -fx-background-radius: 20px; -fx-border-radius: 20px; -fx-padding: 8px 20px; -fx-cursor: hand;" />
    </HBox>

    <!-- Table Section -->
    <VBox VBox.vgrow="ALWAYS" style="-fx-background-color: white; -fx-border-color: #eeeeee; -fx-border-radius: 8px; -fx-border-width: 1px; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 0);">
        <TableView fx:id="staffTable" VBox.vgrow="ALWAYS" style="-fx-background-color: white; -fx-border-color: #e0e0e0; -fx-border-radius: 4px; -fx-border-width: 1px;">
            <columns>
                <TableColumn fx:id="colId" prefWidth="80.0" text="ID" style="-fx-alignment: CENTER-LEFT; -fx-padding: 0 0 0 10;" />
                <TableColumn fx:id="colFullName" prefWidth="200.0" text="Full Name" style="-fx-alignment: CENTER-LEFT; -fx-padding: 0 0 0 10;" />
                <TableColumn fx:id="colUsername" prefWidth="150.0" text="Username" style="-fx-alignment: CENTER-LEFT; -fx-padding: 0 0 0 10;" />
                <TableColumn fx:id="colRole" prefWidth="150.0" text="Role" style="-fx-alignment: CENTER-LEFT; -fx-padding: 0 0 0 10;" />
                <TableColumn fx:id="colStatus" prefWidth="100.0" text="Status" style="-fx-alignment: CENTER-LEFT; -fx-padding: 0 0 0 10;" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>
    </VBox>
</VBox>
