<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefWidth="480.0" spacing="25.0" stylesheets="@../ticket/ticket.css" style="-fx-background-color: white; -fx-background-radius: 12px; -fx-border-radius: 12px;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.admin.StaffDialogController">
    <padding>
        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
    </padding>

    <VBox spacing="5.0">
        <Label fx:id="titleLabel" text="Add New Staff" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #111827;" />
        <Label text="Enter the details below to configure the staff account." style="-fx-font-size: 14px; -fx-text-fill: #6b7280;" />
    </VBox>

    <VBox spacing="20.0">
        <!-- Full Name -->
        <VBox spacing="8.0">
            <Label text="Full Name" style="-fx-text-fill: #374151; -fx-font-size: 14px; -fx-font-weight: bold;" />
            <TextField fx:id="fullNameField" promptText="e.g. Jane Doe" prefHeight="40.0" styleClass="search-field" />
        </VBox>

        <!-- Username -->
        <VBox spacing="8.0">
            <Label text="Username" style="-fx-text-fill: #374151; -fx-font-size: 14px; -fx-font-weight: bold;" />
            <TextField fx:id="usernameField" promptText="e.g. janedoe123" prefHeight="40.0" styleClass="search-field" />
        </VBox>

        <!-- Password -->
        <VBox spacing="8.0">
            <Label text="Password" style="-fx-text-fill: #374151; -fx-font-size: 14px; -fx-font-weight: bold;" />
            <PasswordField fx:id="passwordField" promptText="Leave blank if editing and unchanged" prefHeight="40.0" styleClass="search-field" />
        </VBox>

        <HBox spacing="15.0">
            <!-- Role -->
            <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                <Label text="Role" style="-fx-text-fill: #374151; -fx-font-size: 14px; -fx-font-weight: bold;" />
                <ComboBox fx:id="roleComboBox" prefWidth="400.0" prefHeight="40.0" styleClass="search-combo" />
            </VBox>

            <!-- Status -->
            <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                <Label text="Status" style="-fx-text-fill: #374151; -fx-font-size: 14px; -fx-font-weight: bold;" />
                <ComboBox fx:id="statusComboBox" prefWidth="400.0" prefHeight="40.0" styleClass="search-combo" />
            </VBox>
        </HBox>
    </VBox>

    <HBox alignment="CENTER_RIGHT" spacing="15.0">
        <VBox.margin>
            <Insets top="20.0" />
        </VBox.margin>
        <Button mnemonicParsing="false" onAction="#onCancel" text="Cancel" prefHeight="40.0" prefWidth="100.0" styleClass="search-btn" />
        <Button fx:id="saveButton" mnemonicParsing="false" onAction="#onSave" text="Save Staff" styleClass="action-btn" prefHeight="40.0" prefWidth="120.0" />
    </HBox>
</VBox>
