<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="768.0" prefWidth="774.0" spacing="25.0" style="-fx-background-color: white;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.admin.MovieManagementController">
    <padding>
        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
    </padding>

    <!-- Header Section -->
    <HBox alignment="CENTER_LEFT" spacing="15.0">
        <VBox spacing="5.0">
            <Label text="Movie Management" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #111111;" />
            <Label text="Add and manage your theater's movie catalog." style="-fx-font-size: 14px; -fx-text-fill: #666666;" />
        </VBox>
        <Region HBox.hgrow="ALWAYS" />
        <Button mnemonicParsing="false" onAction="#onAddNewMovie" text="+ Add New Movie" style="-fx-background-color: #0066ff; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px; -fx-background-radius: 20px; -fx-padding: 10px 20px; -fx-cursor: hand;" />
    </HBox>

    <Label text="Currently Licensed Movies" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #111111;" />

    <!-- Movie List -->
    <ScrollPane fitToWidth="true" style="-fx-background-color: white; -fx-border-color: transparent;" VBox.vgrow="ALWAYS">
        <VBox fx:id="moviesListContainer" spacing="15.0" style="-fx-background-color: white;">
            <!-- Movie rows will be dynamically added here -->
            <padding>
                <Insets right="10.0" />
            </padding>
        </VBox>
    </ScrollPane>
</VBox>
