<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.ticket.BookingConfirmedController" stylesheets="@ticket.css">
    
    <!-- Hidden receipt for snapshot -->
    <VBox fx:id="receiptCard" alignment="CENTER" maxWidth="350" minWidth="350" maxHeight="-Infinity" styleClass="receipt-card" spacing="20">
        <padding>
            <Insets top="40" right="30" bottom="40" left="30" />
        </padding>
        <Label text="CINESPHERE TICKET" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #0d6efd;" />
        <Label fx:id="bookingIdLabel" text="Booking ID: BK-1" style="-fx-font-size: 16px; -fx-text-fill: #6c757d;" />
        <VBox fx:id="qrCodeContainer" alignment="CENTER" styleClass="qr-placeholder" prefWidth="180" prefHeight="180" minWidth="180" minHeight="180" maxWidth="180">
            <Label text="[QR Code]" style="-fx-text-fill: #adb5bd; -fx-font-size: 14px;" />
        </VBox>
        <VBox alignment="CENTER" spacing="5">
            <Label fx:id="movieTitleLabel" text="The Dark Knight" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #212529;" />
            <Label fx:id="showtimeLabel" text="14:00:00 - Hall A" style="-fx-font-size: 16px; -fx-text-fill: #6c757d;" />
        </VBox>
        <Separator style="-fx-padding: 10 0;" />
        <Label fx:id="seatsLabel" text="Seats: E7, E8" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #212529;" />
        <Label fx:id="totalPaidLabel" text="Total Paid: \$400.00" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #0d6efd;" />
        <Label fx:id="ticketBadgeLabel" text="CONFIRMED" styleClass="status-badge" style="-fx-font-size: 14px; -fx-translate-y: 20px;" />
    </VBox>
    
    <!-- Main Beautiful UI covering everything -->
    <VBox fx:id="mainSuccessUI" alignment="CENTER" spacing="40" style="-fx-background-color: #f8f9fa;">
        
        <!-- Big Checkmark & Heading -->
        <VBox alignment="CENTER" spacing="10">
            <StackPane>
                <Region style="-fx-background-color: #d1e7dd; -fx-background-radius: 50%; -fx-min-width: 100; -fx-min-height: 100; -fx-max-width: 100; -fx-max-height: 100;" />
                <Label text="✓" style="-fx-font-size: 60px; -fx-text-fill: #198754; -fx-font-weight: bold;" />
            </StackPane>
            <Region prefHeight="10" />
            <Label text="Booking Successful!" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #212529;" />
            <Label text="Your tickets are confirmed and ready for the customer." style="-fx-font-size: 16px; -fx-text-fill: #6c757d;" />
        </VBox>

        <!-- Clean Summary Card -->
        <VBox alignment="CENTER" spacing="15" maxWidth="500" style="-fx-background-color: #ffffff; -fx-padding: 30; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 15, 0, 0, 5); -fx-border-color: #e9ecef; -fx-border-radius: 12; -fx-border-width: 1;">
            
            <!-- Display QR on Success Screen -->
            <VBox fx:id="displayQrCodeContainer" alignment="CENTER" prefWidth="150" prefHeight="150" minWidth="150" minHeight="150" maxWidth="150" />
            
            <Label fx:id="displayMovieTitle" text="Movie Title" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #212529;" />
            
            <HBox alignment="CENTER" spacing="40">
                <VBox alignment="CENTER" spacing="5">
                    <Label text="TIME &amp; HALL" style="-fx-font-size: 12px; -fx-text-fill: #adb5bd; -fx-font-weight: bold;" />
                    <Label fx:id="displayShowtime" text="14:00 - Hall A" style="-fx-font-size: 16px; -fx-text-fill: #495057; -fx-font-weight: bold;" />
                </VBox>
                <Separator orientation="VERTICAL" />
                <VBox alignment="CENTER" spacing="5">
                    <Label text="SEATS" style="-fx-font-size: 12px; -fx-text-fill: #adb5bd; -fx-font-weight: bold;" />
                    <Label fx:id="displaySeats" text="A1, A2" style="-fx-font-size: 16px; -fx-text-fill: #495057; -fx-font-weight: bold;" />
                </VBox>
            </HBox>
        </VBox>

        <Region prefHeight="10" />

        <!-- Buttons -->
        <HBox alignment="CENTER" spacing="20">
            <Button text="Download Digital Receipt" styleClass="primary-action-btn" prefWidth="250" prefHeight="45" onAction="#handleDownloadReceipt" style="-fx-font-size: 15px; -fx-font-weight: bold;" />
            <Button text="Back to Dashboard" styleClass="secondary-action-btn" prefWidth="200" prefHeight="45" onAction="#handleBackToDashboard" style="-fx-font-size: 15px; -fx-font-weight: bold;" />
        </HBox>
        
    </VBox>
</StackPane>
