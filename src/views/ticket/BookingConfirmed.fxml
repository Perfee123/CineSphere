<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.ticket.BookingConfirmedController" stylesheets="@ticket.css" style="-fx-background-color: #ffffff;">
    <VBox alignment="CENTER" maxWidth="600" maxHeight="500" styleClass="receipt-card" spacing="20">
        <padding>
            <Insets top="40" right="50" bottom="40" left="50" />
        </padding>

        <!-- Header -->
        <VBox alignment="CENTER" spacing="5">
            <Label text="✓" style="-fx-font-size: 48px; -fx-text-fill: #198754; -fx-font-weight: bold;" />
            <Label text="Booking Confirmed!" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #212529;" />
            <Label fx:id="bookingIdLabel" text="Booking ID: BK-1" style="-fx-font-size: 14px; -fx-text-fill: #6c757d;" />
        </VBox>

        <Region prefHeight="10" />
        <Separator />
        <Region prefHeight="10" />

        <!-- Details & QR -->
        <HBox alignment="CENTER_LEFT" spacing="30">
            <VBox spacing="10" HBox.hgrow="ALWAYS">
                <Label fx:id="movieTitleLabel" text="Movie Title" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #212529;" />
                <Label fx:id="showtimeLabel" text="14:00 - Hall A" style="-fx-font-size: 14px; -fx-text-fill: #6c757d;" />
                
                <Region prefHeight="10" />
                
                <Label fx:id="seatsLabel" text="Seats: -" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #212529;" />
                <Label fx:id="totalPaidLabel" text="Total Paid: \$0.00" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #0d6efd;" />
            </VBox>
            
            <!-- QR Placeholder -->
            <VBox fx:id="qrCodeContainer" alignment="CENTER" styleClass="qr-placeholder" prefWidth="120" prefHeight="120" minWidth="120" minHeight="120">
                <Label text="[QR Code]" style="-fx-text-fill: #adb5bd; -fx-font-size: 12px;" />
            </VBox>
        </HBox>

        <Region prefHeight="20" />

        <!-- Actions -->
        <VBox spacing="15" alignment="CENTER">
            <Button text="Download Digital Receipt (PNG)" styleClass="primary-action-btn" maxWidth="Infinity" onAction="#handleDownloadReceipt" />
            <HBox alignment="CENTER" spacing="20">
                <Button text="Back to Dashboard" styleClass="secondary-action-btn" onAction="#handleBackToDashboard" />
                <Button text="Ticket Desk →" styleClass="secondary-action-btn" onAction="#handleTicketDesk" />
            </HBox>
        </VBox>
    </VBox>
</StackPane>
