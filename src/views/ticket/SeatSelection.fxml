<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.ticket.SeatSelectionController" stylesheets="@ticket.css" style="-fx-background-color: #ffffff; -fx-padding: 30;">
    
    <!-- Top Bar -->
    <HBox>
        <Button text="← Back to selecting movies" styleClass="back-btn" onAction="#handleBack" />
    </HBox>

    <HBox spacing="30" VBox.vgrow="ALWAYS">
        <!-- Left: Seat Grid Area -->
        <VBox HBox.hgrow="ALWAYS" alignment="TOP_CENTER" spacing="20" style="-fx-background-color: #fafafa; -fx-background-radius: 10; -fx-padding: 30;">
            <Label text="SCREEN" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #6c757d;" />
            <Region style="-fx-background-color: #dee2e6; -fx-pref-height: 4px; -fx-max-width: 600px; -fx-background-radius: 2;" />
            
            <Region prefHeight="10" />
            
            <!-- Grid generated via code -->
            <GridPane fx:id="seatGrid" hgap="10" vgap="10" alignment="CENTER" />
            
            <Region prefHeight="20" VBox.vgrow="ALWAYS" />
            
            <!-- Legend -->
            <HBox spacing="20" alignment="CENTER">
                <HBox alignment="CENTER" spacing="5">
                    <Region style="-fx-background-color: white; -fx-border-color: #e5e7eb; -fx-border-radius: 4; -fx-background-radius: 4; -fx-pref-width: 16; -fx-pref-height: 16;" />
                    <Label text="Available" style="-fx-font-size: 12px; -fx-text-fill: #6c757d;" />
                </HBox>
                <HBox alignment="CENTER" spacing="5">
                    <Region style="-fx-background-color: #0d6efd; -fx-background-radius: 4; -fx-pref-width: 16; -fx-pref-height: 16;" />
                    <Label text="Selected" style="-fx-font-size: 12px; -fx-text-fill: #6c757d;" />
                </HBox>
                <HBox alignment="CENTER" spacing="5">
                    <Region style="-fx-background-color: #6c757d; -fx-background-radius: 4; -fx-pref-width: 16; -fx-pref-height: 16;" />
                    <Label text="Booked" style="-fx-font-size: 12px; -fx-text-fill: #6c757d;" />
                </HBox>
                <HBox alignment="CENTER" spacing="5">
                    <Region style="-fx-background-color: #ffc107; -fx-background-radius: 4; -fx-pref-width: 16; -fx-pref-height: 16;" />
                    <Label text="Maintenance" style="-fx-font-size: 12px; -fx-text-fill: #6c757d;" />
                </HBox>
            </HBox>
        </VBox>

        <!-- Right: Summary Card Area -->
        <VBox prefWidth="350" spacing="20" alignment="TOP_LEFT">
            <Label fx:id="movieTitleLabel" text="Movie Title" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #212529;" />
            <Label fx:id="showtimeLabel" text="14:00 - Hall A" style="-fx-font-size: 14px; -fx-text-fill: #6c757d;" />

            <VBox styleClass="summary-card" spacing="20">
                <HBox alignment="CENTER_LEFT">
                    <Label text="Selected Seats" style="-fx-font-size: 14px; -fx-text-fill: #6c757d;" HBox.hgrow="ALWAYS" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Button text="Clear All" styleClass="clear-btn" onAction="#handleClearSeats" />
                </HBox>
                <Label fx:id="selectedSeatsLabel" text="-" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #212529;" wrapText="true" />
                
                <Separator />
                
                <!-- Adult Counter -->
                <HBox alignment="CENTER_LEFT">
                    <VBox spacing="2">
                        <Label text="Adult" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #212529;" />
                        <Label text="\$350.00" style="-fx-font-size: 12px; -fx-text-fill: #6c757d;" />
                    </VBox>
                    <Region HBox.hgrow="ALWAYS" />
                    <HBox alignment="CENTER" spacing="0">
                        <Button text="-" styleClass="counter-btn" onAction="#decrementAdult" />
                        <Label fx:id="adultCountLabel" text="0" styleClass="counter-label" />
                        <Button text="+" styleClass="counter-btn" onAction="#incrementAdult" />
                    </HBox>
                </HBox>

                <!-- Child Counter -->
                <HBox alignment="CENTER_LEFT">
                    <VBox spacing="2">
                        <Label text="Child" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #212529;" />
                        <Label text="\$200.00" style="-fx-font-size: 12px; -fx-text-fill: #6c757d;" />
                    </VBox>
                    <Region HBox.hgrow="ALWAYS" />
                    <HBox alignment="CENTER" spacing="0">
                        <Button text="-" styleClass="counter-btn" onAction="#decrementChild" />
                        <Label fx:id="childCountLabel" text="0" styleClass="counter-label" />
                        <Button text="+" styleClass="counter-btn" onAction="#incrementChild" />
                    </HBox>
                </HBox>
                
                <Separator />
                
                <HBox alignment="CENTER_LEFT">
                    <Label text="Total Amount" style="-fx-font-size: 14px; -fx-text-fill: #6c757d;" HBox.hgrow="ALWAYS" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Label fx:id="totalAmountLabel" text="\$0.00" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #0d6efd;" />
                </HBox>
            </VBox>

            <!-- Proceed Button -->
            <Button fx:id="proceedBtn" text="Proceed to Book" styleClass="primary-action-btn-disabled" disable="true" onAction="#handleProceed" maxWidth="Infinity" />
        </VBox>
    </HBox>
</VBox>
