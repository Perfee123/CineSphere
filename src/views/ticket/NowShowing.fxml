<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="30" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.ticket.NowShowingController" stylesheets="@ticket.css" style="-fx-background-color: #ffffff; -fx-padding: 40;">
    
    <!-- Top Header & Controls -->
    <HBox alignment="CENTER_LEFT">
        <VBox spacing="5">
            <Label text="Now Showing" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #212529;" />
            <Label text="Browse currently active movies across all halls." style="-fx-font-size: 14px; -fx-text-fill: #6c757d;" />
        </VBox>
        <Region HBox.hgrow="ALWAYS" />
        <HBox alignment="CENTER" spacing="15">
            <ComboBox fx:id="genreFilterCombo" promptText="All Genres" styleClass="search-combo" style="-fx-pref-width: 150;" />
            <TextField fx:id="searchField" promptText="Search movies..." styleClass="search-field" />
            <Button text="Search" styleClass="action-btn" />
        </HBox>
    </HBox>

    <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-border-color: transparent;" VBox.vgrow="ALWAYS">
        <FlowPane fx:id="moviesGrid" hgap="30" vgap="30" style="-fx-background-color: transparent;" />
    </ScrollPane>

</VBox>
