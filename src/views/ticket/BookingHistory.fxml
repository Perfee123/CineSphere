<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.ticket.BookingHistoryController" stylesheets="@ticket.css" style="-fx-background-color: #ffffff; -fx-padding: 30;">
    
    <!-- Top Header & Controls -->
    <HBox alignment="CENTER_LEFT">
        <VBox spacing="5">
            <Label text="Ticket Desk" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #212529;" />
            <Label text="View past transactions and receipts." style="-fx-font-size: 14px; -fx-text-fill: #6c757d;" />
        </VBox>
        <Region HBox.hgrow="ALWAYS" />
        <HBox alignment="CENTER" spacing="15">
            <ComboBox fx:id="statusFilterCombo" promptText="All Statuses" styleClass="search-combo" style="-fx-pref-width: 150;" />
            <TextField fx:id="searchField" promptText="Booking ID or Movie..." styleClass="search-field" />
            <Button text="Search" styleClass="action-btn" />
        </HBox>
    </HBox>

    <Region prefHeight="10" />

    <!-- Table -->
    <TableView fx:id="historyTable" VBox.vgrow="ALWAYS" styleClass="shows-table">
        <columns>
            <TableColumn fx:id="colId" text="Booking ID" prefWidth="120" />
            <TableColumn fx:id="colDate" text="Date" prefWidth="180" />
            <TableColumn fx:id="colMovie" text="Movie Title" prefWidth="250" />
            <TableColumn fx:id="colHall" text="Hall" prefWidth="100" />
            <TableColumn fx:id="colTickets" text="Tickets" prefWidth="80" />
            <TableColumn fx:id="colStatus" text="Status" prefWidth="120" />
            <TableColumn fx:id="colAmount" text="Amount" prefWidth="120" />
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
    </TableView>

    <!-- Footer -->
    <HBox alignment="CENTER_LEFT" spacing="20">
        <Button text="Download Receipt" styleClass="secondary-action-btn" onAction="#handleDownloadReceipt" />
        <Region HBox.hgrow="ALWAYS" />
        <HBox alignment="CENTER" spacing="15" style="-fx-background-color: #f8f9fa; -fx-padding: 10 20; -fx-background-radius: 8; -fx-border-color: #e5e7eb; -fx-border-radius: 8;">
            <Label fx:id="totalTicketsLabel" text="Total Tickets: 0" style="-fx-font-size: 14px; -fx-text-fill: #6c757d;" />
            <Label text="|" style="-fx-font-size: 14px; -fx-text-fill: #dee2e6;" />
            <Label fx:id="confirmedTicketsLabel" text="Confirmed: 0" style="-fx-font-size: 14px; -fx-text-fill: #0d6efd; -fx-font-weight: bold;" />
            <Label text="|" style="-fx-font-size: 14px; -fx-text-fill: #dee2e6;" />
            <Label fx:id="cancelledTicketsLabel" text="Cancellations: 0" style="-fx-font-size: 14px; -fx-text-fill: #dc3545; -fx-font-weight: bold;" />
            <Label text="|" style="-fx-font-size: 14px; -fx-text-fill: #dee2e6;" />
            <Label text="Total Earnings:" style="-fx-font-size: 14px; -fx-text-fill: #6c757d;" />
            <Label fx:id="totalEarningsLabel" text="\$0.00" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #0d6efd;" />
        </HBox>
    </HBox>
</VBox>
