<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefHeight="600.0" prefWidth="800.0" spacing="20.0" style="-fx-background-color: white;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.LoginController">
    <padding>
        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
    </padding>

    <VBox alignment="CENTER" spacing="5.0">
        <Label text="CineSphere" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #111111;" />
        <Label text="Cinema Theater Management" style="-fx-font-size: 14px; -fx-text-fill: #777777;" />
    </VBox>

    <VBox alignment="CENTER_LEFT" maxWidth="280.0" spacing="5.0">
        <VBox.margin>
            <Insets top="20.0" />
        </VBox.margin>
        <Label text="Username" style="-fx-font-size: 12px; -fx-text-fill: #666666;" />
        <TextField fx:id="usernameField" promptText="Enter your username" style="-fx-pref-height: 40px; -fx-background-radius: 5; -fx-border-radius: 5; -fx-border-color: #cccccc; -fx-background-color: white;" />
    </VBox>

    <VBox alignment="CENTER_LEFT" maxWidth="280.0" spacing="5.0">
        <Label text="Password" style="-fx-font-size: 12px; -fx-text-fill: #666666;" />
        <PasswordField fx:id="passwordField" promptText="Enter your password" style="-fx-pref-height: 40px; -fx-background-radius: 5; -fx-border-radius: 5; -fx-border-color: #cccccc; -fx-background-color: white;" />
    </VBox>

    <Label fx:id="errorLabel" text="Please enter both username and password." style="-fx-text-fill: #dc3545; -fx-font-size: 12px;" visible="false" managed="false" />

    <Button fx:id="loginButton" mnemonicParsing="false" onAction="#handleLogin" text="Sign In" textFill="WHITE" style="-fx-background-color: #0d6efd; -fx-pref-height: 45px; -fx-pref-width: 280.0; -fx-background-radius: 25; -fx-font-size: 14px; -fx-font-weight: bold; -fx-cursor: hand;">
        <VBox.margin>
            <Insets top="10.0" />
        </VBox.margin>
    </Button>

    <Label text="© 2026 CineSphere" style="-fx-font-size: 11px; -fx-text-fill: #999999;">
        <VBox.margin>
            <Insets top="20.0" />
        </VBox.margin>
    </Label>

</VBox>
