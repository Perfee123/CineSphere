<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-border-color: transparent;" stylesheets="@../ticket/ticket.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.scheduler.DiscountManagementController">
    <VBox spacing="40" style="-fx-background-color: #f8f9fa; -fx-padding: 40;">
        
        <VBox spacing="5">
            <Label text="Discount &amp; Promo Management" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #212529;"/>
            <Label text="Manage direct pricing discounts and global promo codes." style="-fx-font-size: 14px; -fx-text-fill: #6c757d;"/>
        </VBox>
        
        <!-- Direct Discounts Section -->
        <VBox spacing="20">
            <HBox alignment="CENTER_LEFT">
                <VBox spacing="5">
                    <Label text="Direct Discounts" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #212529;"/>
                    <Label text="Discounts applied automatically to specific items." style="-fx-font-size: 14px; -fx-text-fill: #6c757d;"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <Button text="+ Add Discount" onAction="#openAddDiscountDialog" styleClass="action-btn" />
            </HBox>
            
            <TableView fx:id="discountsTable" prefHeight="300" styleClass="shows-table">
                <columns>
                    <TableColumn fx:id="idColumn" text="ID" prefWidth="50" />
                    <TableColumn fx:id="targetTypeColumn" text="Target Type" prefWidth="150" />
                    <TableColumn fx:id="targetNameColumn" text="Target Name" prefWidth="300" />
                    <TableColumn fx:id="discountPercentageColumn" text="Discount %" prefWidth="150" />
                    <TableColumn fx:id="statusColumn" text="Status" prefWidth="150" />
                    <TableColumn fx:id="discountActionColumn" text="Actions" prefWidth="150" />
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                </columnResizePolicy>
            </TableView>
        </VBox>
        
        <Separator />
        
        <!-- Promo Codes Section -->
        <VBox spacing="20">
            <HBox alignment="CENTER_LEFT">
                <VBox spacing="5">
                    <Label text="Promo Codes" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #212529;"/>
                    <Label text="Global codes applied at checkout." style="-fx-font-size: 14px; -fx-text-fill: #6c757d;"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <Button text="+ Add Promo Code" onAction="#openAddPromoDialog" styleClass="action-btn" />
            </HBox>
            
            <TableView fx:id="promoTable" prefHeight="300" styleClass="shows-table">
                <columns>
                    <TableColumn fx:id="promoIdColumn" text="ID" prefWidth="50" />
                    <TableColumn fx:id="promoCodeColumn" text="Promo Code" prefWidth="300" />
                    <TableColumn fx:id="promoDiscountColumn" text="Discount %" prefWidth="150" />
                    <TableColumn fx:id="promoStatusColumn" text="Status" prefWidth="150" />
                    <TableColumn fx:id="promoActionColumn" text="Actions" prefWidth="150" />
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                </columnResizePolicy>
            </TableView>
        </VBox>
        
    </VBox>
</ScrollPane>
