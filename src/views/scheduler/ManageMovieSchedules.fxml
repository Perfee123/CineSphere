<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.scheduler.ManageMovieSchedulesController"
      spacing="15" style="-fx-background-color: #f8f9fa; -fx-padding: 40;" stylesheets="@../ticket/ticket.css">
    
    <!-- Back Button -->
    <Button text="← Back to Movies" onAction="#handleBack" style="-fx-background-color: transparent; -fx-text-fill: #3b82f6; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 0; -fx-cursor: hand;" />
    
    <HBox alignment="CENTER_LEFT">
        <VBox spacing="5">
            <Label fx:id="movieTitleLabel" text="Movie Title" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #212529;"/>
            <Label text="Manage all schedules allocated for this movie." style="-fx-font-size: 14px; -fx-text-fill: #6c757d;"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS" />
        <Button text="+ Add Schedule" onAction="#handleAddSchedule" styleClass="action-btn" />
    </HBox>
    
    <Region prefHeight="15" />
    
    <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-border-color: transparent;" VBox.vgrow="ALWAYS">
        <FlowPane fx:id="schedulesGrid" hgap="20" vgap="20" style="-fx-background-color: transparent;" />
    </ScrollPane>
    
</VBox>
