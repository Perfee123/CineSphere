<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import atlantafx.base.controls.RingProgressIndicator?>

<StackPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.scheduler.HallManagementController">
    <!-- Main Content -->
    <VBox fx:id="mainContent" spacing="20" style="-fx-background-color: #f8f9fa; -fx-padding: 40;" stylesheets="@../ticket/ticket.css">
        
        <HBox alignment="CENTER_LEFT" spacing="20">
            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT" spacing="15">
                    <Label text="Hall Management" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #111111;"/>
                </HBox>
                <Label text="Manage halls and their capacities." style="-fx-font-size: 14px; -fx-text-fill: #6c757d;"/>
            </VBox>
            <Button text="+ Add New Hall" onAction="#handleAddNewHall" styleClass="primary-action-btn" prefHeight="40" />
        </HBox>
        
        <ScrollPane fitToWidth="true" fitToHeight="true" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;">
            <FlowPane fx:id="hallsContainer" hgap="20" vgap="20" />
        </ScrollPane>
    </VBox>
    
    <!-- Loading Overlay -->
    <VBox fx:id="loadingOverlay" alignment="CENTER" spacing="15" style="-fx-background-color: rgba(255, 255, 255, 0.8);" visible="false" managed="false">
        <RingProgressIndicator progress="-1" />
        <Label text="Adding Hall... Please wait" style="-fx-font-size: 18px; -fx-text-fill: #6c757d; -fx-font-weight: bold;"/>
    </VBox>
</StackPane>
