<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="768.0" prefWidth="1024.0" stylesheets="@sidebar.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.MainLayoutController">
    <left>
        <VBox fx:id="sidebar" prefWidth="250.0" spacing="10.0" styleClass="sidebar" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="30.0" left="0" right="0" top="30.0" />
            </padding>
            <VBox spacing="2.0">
                <padding><Insets left="20.0" right="20.0" /></padding>
                <Label text="CineSphere." style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;" />
                <Label fx:id="roleLabel" text="SYSTEM ADMIN" style="-fx-text-fill: #888888; -fx-font-size: 11px;" />
            </VBox>
            
            <Region prefHeight="30.0" />
            
            <VBox fx:id="navMenu" spacing="0" VBox.vgrow="ALWAYS" />
            
            <Region VBox.vgrow="ALWAYS" />
            
            <VBox spacing="2.0">
                <padding><Insets left="20.0" right="20.0" /></padding>
                <Label fx:id="nameLabel" text="System Administrator" style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;" />
                <Label fx:id="bottomRoleLabel" text="Administrator" style="-fx-text-fill: #888888; -fx-font-size: 12px;" />
                <Button mnemonicParsing="false" onAction="#handleSignOut" styleClass="sign-out-button" text="Sign out">
                    <VBox.margin>
                        <Insets top="15.0" />
                    </VBox.margin>
                </Button>
            </VBox>
        </VBox>
    </left>
    <center>
        <StackPane fx:id="contentArea" id="contentArea" style="-fx-background-color: #f8f9fa;" BorderPane.alignment="CENTER" />
    </center>
</BorderPane>
