<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="768.0" prefWidth="1024.0" spacing="30.0" style="-fx-background-color: #f8f9fa;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.snackbar.SnackManagementController" stylesheets="@../ticket/ticket.css">
    <padding>
        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
    </padding>

    <!-- Header Section -->
    <HBox alignment="CENTER_LEFT" spacing="15.0">
        <VBox spacing="5.0">
            <Label text="Snack Management" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #111111;" />
            <Label text="Manage snack inventory, pricing, and stock." style="-fx-font-size: 14px; -fx-text-fill: #666666;" />
        </VBox>
        <Region HBox.hgrow="ALWAYS" />
        
        <ComboBox fx:id="categoryFilter" promptText="All Categories" style="-fx-background-radius: 20px; -fx-border-color: #dddddd; -fx-border-radius: 20px; -fx-background-color: white;" />
        <TextField fx:id="searchField" prefWidth="250.0" promptText="Search snacks..." style="-fx-background-radius: 20px; -fx-padding: 8px 15px; -fx-border-color: #dddddd; -fx-border-radius: 20px; -fx-background-color: white;" />
        
        <Button mnemonicParsing="false" onAction="#onAddSnack" text="+ Add Snack" style="-fx-background-color: #0066ff; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px; -fx-background-radius: 20px; -fx-padding: 8px 20px; -fx-cursor: hand;" />
    </HBox>

    <!-- FlowPane for Snack Cards -->
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent; -fx-background: transparent;">
        <FlowPane fx:id="cardsContainer" hgap="20.0" vgap="20.0" style="-fx-padding: 10px;" />
    </ScrollPane>
</VBox>
