<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.cell.PropertyValueFactory?>

<VBox prefHeight="768.0" prefWidth="774.0" spacing="30.0" style="-fx-background-color: #f8f9fa;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.snackbar.SnackOverviewController" stylesheets="@../ticket/ticket.css">
    <padding>
        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
    </padding>

    <!-- Header Section -->
    <HBox alignment="CENTER_LEFT">
        <VBox spacing="5.0">
            <Label text="Snack Bar Overview" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #111111;" />
            <Label text="Welcome to the Snack Bar Dashboard. Here is the inventory and sales summary." style="-fx-font-size: 14px; -fx-text-fill: #666666;" />
        </VBox>
        <Region HBox.hgrow="ALWAYS" />
    </HBox>

    <!-- Cards Section -->
    <HBox spacing="20.0">
        <!-- Card 1 -->
        <VBox style="-fx-background-color: white; -fx-background-radius: 8px; -fx-border-color: #e0e0e0; -fx-border-radius: 8px; -fx-border-width: 1px;" HBox.hgrow="ALWAYS">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>
            <Label text="Total Snacks" style="-fx-font-size: 13px; -fx-text-fill: #888888;" />
            <Label fx:id="totalSnacksLabel" text="0" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #111111;" />
            <Label text="Active items in inventory" style="-fx-font-size: 12px; -fx-text-fill: #999999;" />
        </VBox>

        <!-- Card 2 -->
        <VBox style="-fx-background-color: white; -fx-background-radius: 8px; -fx-border-color: #e0e0e0; -fx-border-radius: 8px; -fx-border-width: 1px;" HBox.hgrow="ALWAYS">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>
            <Label text="Low Stock Items" style="-fx-font-size: 13px; -fx-text-fill: #888888;" />
            <Label fx:id="lowStockLabel" text="0" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #ff3333;" />
            <Label text="Items below 10 qty" style="-fx-font-size: 12px; -fx-text-fill: #999999;" />
        </VBox>

        <!-- Card 3 -->
        <VBox style="-fx-background-color: white; -fx-background-radius: 8px; -fx-border-color: #e0e0e0; -fx-border-radius: 8px; -fx-border-width: 1px;" HBox.hgrow="ALWAYS">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>
            <Label text="Total Sales Today" style="-fx-font-size: 13px; -fx-text-fill: #888888;" />
            <Label fx:id="totalSalesTodayLabel" text="0" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #111111;" />
            <Label text="Number of transactions" style="-fx-font-size: 12px; -fx-text-fill: #999999;" />
        </VBox>

        <!-- Card 4 -->
        <VBox style="-fx-background-color: white; -fx-background-radius: 8px; -fx-border-color: #e0e0e0; -fx-border-radius: 8px; -fx-border-width: 1px;" HBox.hgrow="ALWAYS">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>
            <Label text="Revenue Today" style="-fx-font-size: 13px; -fx-text-fill: #888888;" />
            <Label fx:id="revenueTodayLabel" text="0.00" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #111111;" />
            <Label text="Total daily income" style="-fx-font-size: 12px; -fx-text-fill: #999999;" />
        </VBox>
    </HBox>

    <!-- Low Stock Table Section -->
    <VBox spacing="10.0" VBox.vgrow="ALWAYS">
        <Label text="Low Stock Alerts" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #111111;" />
        
        <TableView fx:id="lowStockTable" VBox.vgrow="ALWAYS" style="-fx-background-color: white; -fx-border-color: #e0e0e0; -fx-border-radius: 4px; -fx-border-width: 1px;">
            <columns>
                <TableColumn fx:id="colId" prefWidth="80.0" text="Snack ID" />
                <TableColumn fx:id="colName" prefWidth="250.0" text="Snack Name" />
                <TableColumn fx:id="colCategory" prefWidth="150.0" text="Category" />
                <TableColumn fx:id="colPrice" prefWidth="120.0" text="Price" />
                <TableColumn fx:id="colQuantity" prefWidth="100.0" text="Quantity" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>
    </VBox>
</VBox>
