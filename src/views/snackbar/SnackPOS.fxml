<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="768.0" prefWidth="1024.0" spacing="20.0" style="-fx-background-color: #f8f9fa;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.snackbar.SnackPOSController" stylesheets="@../ticket/ticket.css">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <!-- Header Section -->
    <HBox alignment="CENTER_LEFT">
        <VBox spacing="5.0">
            <Label text="Point of Sale" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #111111;" />
            <Label text="Process snack sales and generate bills." style="-fx-font-size: 14px; -fx-text-fill: #666666;" />
        </VBox>
    </HBox>

    <HBox spacing="20.0" VBox.vgrow="ALWAYS">
        <!-- Left Side: Product Selection (Card Deck) -->
        <VBox spacing="15.0" HBox.hgrow="ALWAYS" style="-fx-background-color: white; -fx-background-radius: 8px; -fx-padding: 20px; -fx-border-color: #e0e0e0; -fx-border-radius: 8px;">
            
            <HBox alignment="CENTER_LEFT" spacing="10.0">
                <Label text="Available Snacks" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #111111;" />
                <Region HBox.hgrow="ALWAYS" />
                <ComboBox fx:id="categoryFilter" promptText="All Categories" style="-fx-background-radius: 20px; -fx-border-color: #dddddd; -fx-border-radius: 20px; -fx-background-color: white;" />
                <TextField fx:id="searchField" prefWidth="200.0" promptText="Search snacks..." style="-fx-background-radius: 20px; -fx-padding: 8px 15px; -fx-border-color: #dddddd; -fx-border-radius: 20px;" />
            </HBox>

            <!-- FlowPane for Snack Cards inside ScrollPane -->
            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: #e0e0e0; -fx-border-radius: 4px;">
                <content>
                    <FlowPane fx:id="cardsContainer" hgap="15.0" vgap="15.0" style="-fx-padding: 10px;" />
                </content>
            </ScrollPane>
        </VBox>

        <!-- Right Side: Cart & Checkout -->
        <VBox prefWidth="450.0" spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 8px; -fx-padding: 20px; -fx-border-color: #e0e0e0; -fx-border-radius: 8px; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 0);">
            <Label text="Current Order" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #111111;" />
            
            <TableView fx:id="cartTable" VBox.vgrow="ALWAYS" style="-fx-border-color: #e0e0e0; -fx-border-radius: 4px;">
                <columns>
                    <TableColumn fx:id="cartColName" prefWidth="130.0" text="Item" />
                    <TableColumn fx:id="cartColQty" prefWidth="50.0" text="Qty" />
                    <TableColumn fx:id="cartColPrice" prefWidth="65.0" text="Price" />
                    <TableColumn fx:id="cartColTotal" prefWidth="65.0" text="Total" />
                    <TableColumn fx:id="cartColAction" prefWidth="95.0" text="Action" />
                </columns>
            </TableView>

            <!-- Booking Lookup Section -->
            <VBox spacing="10.0" style="-fx-background-color: #f8f9fa; -fx-padding: 10px; -fx-background-radius: 8px; -fx-border-color: #eeeeee; -fx-border-radius: 8px;">
                <HBox spacing="10.0" alignment="CENTER_LEFT">
                    <Label text="Customer:" style="-fx-font-size: 14px; -fx-text-fill: #666666;" />
                    <ComboBox fx:id="customerTypeCombo" prefWidth="150.0" />
                </HBox>
                <VBox fx:id="bookingLookupBox" spacing="10.0" managed="false" visible="false">
                    <HBox spacing="10.0">
                        <TextField fx:id="bookingIdField" promptText="Booking ID (e.g. BK-1 or 1)" HBox.hgrow="ALWAYS" style="-fx-padding: 5px; -fx-border-color: #cccccc; -fx-border-radius: 4px;" />
                        <Button text="Lookup" onAction="#handleBookingLookup" style="-fx-background-color: #17a2b8; -fx-text-fill: white; -fx-background-radius: 4px; -fx-cursor: hand;" />
                    </HBox>
                    <VBox fx:id="bookingDetailsBox" spacing="5.0" managed="false" visible="false" style="-fx-background-color: #e6f2ff; -fx-padding: 10px; -fx-background-radius: 4px; -fx-border-color: #b3d9ff; -fx-border-radius: 4px;">
                        <Label fx:id="bdMovieLabel" text="Movie: N/A" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #004080;" />
                        <Label fx:id="bdHallLabel" text="Hall: N/A" style="-fx-font-size: 12px; -fx-text-fill: #004080;" />
                        <Label fx:id="bdSeatsLabel" text="Seats: N/A" style="-fx-font-size: 12px; -fx-text-fill: #004080;" />
                        <Label fx:id="bdTimeLabel" text="Time: N/A" style="-fx-font-size: 12px; -fx-text-fill: #004080;" />
                    </VBox>
                </VBox>
            </VBox>

            <!-- Totals Section -->
            <VBox spacing="10.0" style="-fx-background-color: #f8f9fa; -fx-padding: 15px; -fx-background-radius: 8px; -fx-border-color: #eeeeee; -fx-border-radius: 8px;">
                <HBox>
                    <Label text="Subtotal:" style="-fx-font-size: 14px; -fx-text-fill: #666666;" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Label fx:id="subtotalLabel" text="0.00" style="-fx-font-size: 14px; -fx-font-weight: bold;" />
                </HBox>
                
                <HBox alignment="CENTER_LEFT" spacing="10.0">
                    <Label text="Discount Code:" style="-fx-font-size: 14px; -fx-text-fill: #666666;" />
                    <TextField fx:id="discountCodeField" promptText="Enter code" prefWidth="120.0" style="-fx-padding: 4px; -fx-border-color: #cccccc; -fx-border-radius: 4px;" />
                    <Button text="Apply" onAction="#handleApplyDiscount" style="-fx-background-color: #6c757d; -fx-text-fill: white; -fx-background-radius: 4px; -fx-cursor: hand;" />
                </HBox>

                <HBox>
                    <Label text="Discount:" style="-fx-font-size: 14px; -fx-text-fill: #28a745;" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Label fx:id="discountLabel" text="-0.00" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #28a745;" />
                </HBox>

                <HBox style="-fx-border-width: 1px 0 0 0; -fx-border-color: #cccccc; -fx-padding: 10px 0 0 0;">
                    <Label text="Total:" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #111111;" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Label fx:id="totalLabel" text="0.00" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #0066ff;" />
                </HBox>
            </VBox>

            <!-- DO NOT USE maxWidth="Infinity", use prefWidth combined with VBox.hgrow or MAX_VALUE in code if needed, but prefWidth is safer -->
            <Button text="Complete Sale" onAction="#handleCheckout" prefWidth="380.0" style="-fx-background-color: #0066ff; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 18px; -fx-background-radius: 8px; -fx-padding: 15px; -fx-cursor: hand;" />
        </VBox>
    </HBox>
</VBox>
