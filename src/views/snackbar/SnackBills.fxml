<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="768.0" prefWidth="1024.0" spacing="20.0" style="-fx-background-color: #f8f9fa;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.snackbar.SnackBillsController" stylesheets="@../ticket/ticket.css">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <!-- Header Section -->
    <HBox alignment="CENTER_LEFT">
        <VBox spacing="5.0">
            <Label text="Bills &amp; Reports" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #111111;" />
            <Label text="View transaction history and detailed sale items." style="-fx-font-size: 14px; -fx-text-fill: #666666;" />
        </VBox>

        <Region HBox.hgrow="ALWAYS" />
        <HBox alignment="CENTER" spacing="10.0">
            <Label text="Filter:" style="-fx-font-weight: bold;" />
            <ComboBox fx:id="dateFilterCombo" prefWidth="150.0" style="-fx-background-radius: 4px;" />
            <HBox fx:id="customDateBox" spacing="5.0" managed="false" visible="false">
                <DatePicker fx:id="startDatePicker" prefWidth="120.0" promptText="Start Date" />
                <DatePicker fx:id="endDatePicker" prefWidth="120.0" promptText="End Date" />
                <Button text="Apply" onAction="#handleApplyCustomDate" style="-fx-background-color: #0066ff; -fx-text-fill: white;" />
            </HBox>
        </HBox>
    </HBox>

    <!-- KPI Row -->
    <HBox spacing="20.0">
        <VBox HBox.hgrow="ALWAYS" alignment="CENTER" style="-fx-background-color: white; -fx-background-radius: 8px; -fx-padding: 15px; -fx-border-color: #e0e0e0; -fx-border-radius: 8px; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 0);">
            <Label text="Total Sales (Count)" style="-fx-font-size: 14px; -fx-text-fill: #888888;" />
            <Label fx:id="totalSalesCountLabel" text="0" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #111111;" />
        </VBox>
        <VBox HBox.hgrow="ALWAYS" alignment="CENTER" style="-fx-background-color: white; -fx-background-radius: 8px; -fx-padding: 15px; -fx-border-color: #e0e0e0; -fx-border-radius: 8px; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 0);">
            <Label text="Total Revenue" style="-fx-font-size: 14px; -fx-text-fill: #888888;" />
            <Label fx:id="totalRevenueLabel" text="\$0.00" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #28a745;" />
        </VBox>
        <VBox HBox.hgrow="ALWAYS" alignment="CENTER" style="-fx-background-color: white; -fx-background-radius: 8px; -fx-padding: 15px; -fx-border-color: #e0e0e0; -fx-border-radius: 8px; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 0);">
            <Label text="Avg Sale Value" style="-fx-font-size: 14px; -fx-text-fill: #888888;" />
            <Label fx:id="avgSaleLabel" text="\$0.00" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #17a2b8;" />
        </VBox>
        <VBox HBox.hgrow="ALWAYS" alignment="CENTER" style="-fx-background-color: white; -fx-background-radius: 8px; -fx-padding: 15px; -fx-border-color: #e0e0e0; -fx-border-radius: 8px; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 0);">
            <Label text="Best Selling Snack" style="-fx-font-size: 14px; -fx-text-fill: #888888;" />
            <Label fx:id="bestSnackLabel" text="N/A" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #fd7e14;" />
        </VBox>
    </HBox>

    <HBox alignment="CENTER_RIGHT" spacing="10.0">
        <Button text="Export CSV" onAction="#handleExportCSV" style="-fx-background-color: #6c757d; -fx-text-fill: white; -fx-cursor: hand;" />
        <Button text="Print Report (PDF)" onAction="#handlePrintReport" style="-fx-background-color: #007bff; -fx-text-fill: white; -fx-cursor: hand;" />
    </HBox>

    <TabPane fx:id="tabPane" VBox.vgrow="ALWAYS" tabClosingPolicy="UNAVAILABLE" style="-fx-background-color: white; -fx-border-color: #e0e0e0; -fx-border-radius: 8px;">
        <tabs>
            <!-- Transaction History Tab -->
            <Tab text="Transaction History">
                <content>
                    <VBox spacing="10.0" style="-fx-padding: 15px;">
                        <TableView fx:id="salesTable" VBox.vgrow="ALWAYS" style="-fx-border-color: #e0e0e0; -fx-border-radius: 4px;">
                            <columns>
                                <TableColumn fx:id="colSaleId" prefWidth="80.0" text="Sale ID" />
                                <TableColumn fx:id="colBookingId" prefWidth="100.0" text="Booking ID" />
                                <TableColumn fx:id="colCashier" prefWidth="120.0" text="Cashier" />
                                <TableColumn fx:id="colAmount" prefWidth="120.0" text="Total Amount ($)" />
                                <TableColumn fx:id="colTime" prefWidth="200.0" text="Sale Date" />
                            </columns>
                        </TableView>
                    </VBox>
                </content>
            </Tab>

            <!-- Sale Items Tab -->
            <Tab text="Sale Items">
                <content>
                    <VBox spacing="10.0" style="-fx-padding: 15px;">
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <Label fx:id="selectedSaleLabel" text="No sale selected" style="-fx-font-weight: bold; -fx-text-fill: #0066ff;" />
                            <Region HBox.hgrow="ALWAYS" />
                            <Button fx:id="printReceiptBtn" text="Print Receipt" onAction="#handlePrintReceipt" visible="false" style="-fx-background-color: #28a745; -fx-text-fill: white; -fx-background-radius: 4px; -fx-cursor: hand; -fx-font-weight: bold;" />
                        </HBox>
                        <TableView fx:id="itemsTable" VBox.vgrow="ALWAYS" style="-fx-border-color: #e0e0e0; -fx-border-radius: 4px;">
                            <columns>
                                <TableColumn fx:id="colItemName" prefWidth="200.0" text="Snack Name" />
                                <TableColumn fx:id="colItemQty" prefWidth="100.0" text="Quantity" />
                                <TableColumn fx:id="colItemPrice" prefWidth="150.0" text="Price @ Sale ($)" />
                                <TableColumn fx:id="colItemDiscount" prefWidth="150.0" text="Discount (%)" />
                                <TableColumn fx:id="colItemTotal" prefWidth="150.0" text="Total ($)" />
                            </columns>
                        </TableView>
                    </VBox>
                </content>
            </Tab>
        </tabs>
    </TabPane>
</VBox>
